# .env.example
# Copy to .env and customize for your environment.
# Never commit .env to version control.

# ── Cache Configuration ────────────────────────────────────────────
# Minimum cosine similarity to consider a cache hit (0.0 - 1.0)
# Higher = stricter matching, fewer hits but more accurate
# Lower  = looser matching, more hits but may return wrong results
CACHE_SIMILARITY_THRESHOLD=0.75

# Maximum number of entries to hold in cache before LRU eviction
CACHE_MAX_SIZE=1000

# Time-to-live in seconds (3600 = 1 hour, set to 0 to disable TTL)
CACHE_TTL_SECONDS=3600

# ── API Configuration ──────────────────────────────────────────────
# Host and port for the Uvicorn server
API_HOST=0.0.0.0
API_PORT=8000

# ── Model Configuration ────────────────────────────────────────────
# Number of GMM clusters (must match the trained model)
N_CLUSTERS=20

# Embedding model (change requires re-running build_embeddings.py)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2